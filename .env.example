# Open-Antigravity LLM Gateway Configuration
# Copy this file to .env and fill in your API keys

# Server
GATEWAY_PORT=4001
GATEWAY_API_KEY=antigravity-local-dev-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google
GOOGLE_API_KEY=...

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434

# Rate Limiting
RATE_LIMIT_MAX=100
