# Open-Antigravity LLM Configuration
# Copy to .env and fill in your API keys. The IDE reads these directly.
# Only ONE key is needed — the IDE auto-detects which providers are available.

# ===== Major Providers =====

# OpenAI
OPENAI_API_KEY=sk-...
# Azure OpenAI (optional, set OPENAI_BASE_URL too)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google
GOOGLE_API_KEY=...

# ===== OpenRouter (200+ models via single API key) =====
OPENROUTER_API_KEY=

# ===== Dedicated Providers =====

# Mistral AI
MISTRAL_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Groq (fast LPU inference)
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Fireworks AI
FIREWORKS_API_KEY=

# Cohere
COHERE_API_KEY=

# Perplexity (Sonar)
PERPLEXITY_API_KEY=

# ===== Local Models =====

# Ollama (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# LM Studio (default: http://localhost:1234)
LMSTUDIO_HOST=http://localhost:1234

# ===== Optional: Standalone Gateway =====
GATEWAY_PORT=4001
GATEWAY_API_KEY=antigravity-local-dev-key
