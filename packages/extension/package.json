{
  "name": "@open-antigravity/extension",
  "displayName": "Open Antigravity",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first AI coding assistant for VS Code",
  "publisher": "open-antigravity",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/devchon2/open-antigravity"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other", "Programming Languages", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-antigravity.openChat",
        "title": "Open Antigravity Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "open-antigravity.openAgentManager",
        "title": "Open Agent Manager"
      },
      {
        "command": "open-antigravity.explainCode",
        "title": "Antigravity: Explain Code"
      },
      {
        "command": "open-antigravity.generateTests",
        "title": "Antigravity: Generate Tests"
      },
      {
        "command": "open-antigravity.sendToAgent",
        "title": "Antigravity: Send to Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "open-antigravity-sidebar",
          "title": "Open Antigravity",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "open-antigravity-sidebar": [
        {
          "id": "open-antigravity.chatView",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "open-antigravity.agentView",
          "name": "Agents",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "open-antigravity.explainCode",
          "group": "open-antigravity",
          "when": "editorHasSelection"
        },
        {
          "command": "open-antigravity.sendToAgent",
          "group": "open-antigravity"
        }
      ]
    },
    "keybindings": [
      {
        "command": "open-antigravity.openChat",
        "key": "ctrl+l",
        "mac": "cmd+l"
      },
      {
        "command": "open-antigravity.openAgentManager",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Open Antigravity",
      "properties": {
        "open-antigravity.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:4001",
          "description": "URL of the LLM Gateway"
        },
        "open-antigravity.gatewayApiKey": {
          "type": "string",
          "default": "antigravity-local-dev-key",
          "description": "API key for the LLM Gateway"
        },
        "open-antigravity.defaultModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default model to use"
        },
        "open-antigravity.agentMode": {
          "type": "string",
          "default": "fast",
          "enum": ["fast", "planning"],
          "description": "Agent mode: fast (direct execution) or planning (plan before acting)"
        },
        "open-antigravity.approvalMode": {
          "type": "string",
          "default": "always",
          "enum": ["always", "never", "agent_decides"],
          "description": "Approval mode: always (ask before every action), never (auto-approve), agent_decides (agent chooses)"
        },
        "open-antigravity.terminalAllowList": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["npm test", "npm run", "git status", "git diff", "ls", "dir", "cat", "echo"],
          "description": "Commands allowed without approval"
        },
        "open-antigravity.terminalDenyList": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["rm -rf /", "sudo", "git push --force", "shutdown", "reboot"],
          "description": "Commands always blocked"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "dev": "npm run watch",
    "build": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@open-antigravity/shared": "*"
  }
}
